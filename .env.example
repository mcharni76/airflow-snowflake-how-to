# .env Configuration Template
# Copy this to .env and fill in your values

# Snowflake Connection (key-pair auth)
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PRIVATE_KEY_PATH=~/.ssh/your_rsa_key.p8
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=EVENTS_DEV
SNOWFLAKE_ROLE=EVENTS_DEV_ROLE
SNOWFLAKE_NAMED_STAGE=EVENTS_DEV.RAW.TICKETING_STAGE

# Mock API
TICKETING_API_BASE_URL=http://mock-api:8099
TICKETING_API_TOKEN=dev-token-events-2026
TICKETING_API_PAGE_SIZE=100

# Pipeline Settings
BRONZE_POLL_INTERVAL_SEC=15
BRONZE_TIMEOUT_SEC=600

# Airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
